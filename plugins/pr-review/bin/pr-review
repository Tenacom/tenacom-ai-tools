#!/usr/bin/env bash
# pr-review — prepare a GitHub PR and review it in a sandboxed Claude session.
# Usage:  pr-review <pr_id>
#         pr-review prepare <pr_id>
#
#   prepare       prepare the working tree and stop — no review session.
#                 For when you want to inspect the tree first.
#                 Review later with `pr-review <pr_id>`, or with /pr-review:run
#                 from a Claude session standing on the pr/<id> branch.
#   <pr_id>       the pull request number
#
# Posting the curated REVIEW.md back to GitHub is a separate tool, `pr-finalize`
# (a self-contained Python program): this script prepares and reviews; that one
# posts. They meet only at the .pr-review/state.json file contract. After a
# finalize, pr-finalize leaves a `.pr-review-run/posted.md` marker — this script
# honours it below, refusing to relaunch a review of an already-posted preparation.
#
# Self-contained — the whole preparation lives in this file, so it can be aliased
# or copied into a bin directory freely; it never relies on its own location.
# Portable Ubuntu/WSL bash, no other runtime. Requires git, and on the prepare
# path gh (authenticated, with a default repo set via `gh repo set-default`);
# claude on PATH unless prepare is specified.
#
# What it does, in order: require the repository root (REVIEW.md and its relative
# anchors live there). If REVIEW.md already exists for this PR on the prepared
# branch (snapshot included), skip preparation — re-prepping could move HEAD and
# orphan the file's anchors — and go straight to the review session. Otherwise
# prepare: read gh's default repo as the canonical/upstream truth, match it to a
# local remote by URL (renamed remotes are fine), fetch, capture the PR snapshot
# (PR title/body/metadata and every referenced issue, plus — post-rebase — the
# canonical diff) into .pr-review/, assemble the review's rule set from the BASE
# branch (via pr-assemble-rules, so a PR cannot rewrite the rules it is judged
# against — the CODEOWNERS trick), (re)create the local base branch, use
# `gh pr checkout` to make a clean pr/<id> (works for fork PRs with no per-fork
# remote — gh points the branch's tracking config at the fork directly), and
# rebase onto the base if behind. If a rebase was applied, ask on the terminal
# and force-push the rebased branch (--force-with-lease: fails rather than
# clobber anything pushed to the PR meanwhile). The push is part of the
# preparation — review links must match the PR head on GitHub, so no push means
# no review; declining, or a failed push, fails the preparation. Idempotent: a
# re-run finds no rebase needed and asks nothing. Then, if the repo opts in with
# a .claude/pr-review/sync-deps.sh, run it (from the BASE branch) to sync the
# installed dependencies to the PR's manifests. Finally launch `claude`
# interactively, sandbox enabled for this session only (via --settings;
# .claude/settings.local.json is never touched), with "/pr-review:run"
# as the initial prompt. Preparation runs OUTSIDE the sandbox (it needs network
# and .git/config writes); the review runs INSIDE it with ZERO egress — all its
# GitHub context comes from the snapshot, so the sandbox needs no GitHub hole.
# This script is that boundary.
#
# stdout: on the prepare path, a single JSON object describing the prepared state.
# stderr: progress, the force-push prompt, and all errors. Exits non-zero on any
# failure.

set -euo pipefail

log() { printf '  %s\n' "$*" >&2; }
die() { printf 'pr-review: %s\n' "$*" >&2; exit 1; }

# The review runs sandboxed with a fixed profile, applied only to this session via --settings
# (.claude/settings.local.json is never touched). What each layer is really for:
#   - sandbox: OS-level containment (bubblewrap on Linux/WSL2, Seatbelt on macOS) — the real
#     boundary. failIfUnavailable makes a sandbox that cannot start a hard stop, never a silent
#     unsandboxed run. filesystem.denyWrite scopes the integrity-critical paths read-only for Bash
#     and its children — .git (no planted hook) plus the review's own snapshot (.pr-review) and run
#     (.pr-review-run) directories, so executed PR code can alter none of them. It does NOT deny the
#     whole repo root: bubblewrap read-only-binds a set of hardened dotfiles (.gitconfig and kin) over
#     the working dir, and to bind one it must create the mount point if absent — inside a read-only
#     working tree that create fails ("Read-only file system"), aborting the sandbox before any command
#     runs, so EVERY Bash call dies. Leaving the working tree writable lets those mount points be
#     created; the review's own Bash is read-only anyway (search + git rev-parse/merge-base), it never
#     executes PR code (SKILL never-execute rule), and Read/Edit/Write bypass the sandbox so agents
#     still write REVIEW.md and the run dir. REVIEW.md is intentionally not in denyWrite — it may not
#     exist yet on a first run, and denying an absent path would reintroduce the same phantom-mount
#     abort. Egress is sealed by the network proxy (no domain allowed), independent of the deny list.
#     sandbox.credentials is deliberately NOT set: with no egress and denyWrite, a secret read is inert,
#     and a user who needs it sets it globally where it merges in.
#   - permissions: the search allow list, and a deny list kept to capabilities a name can COMPLETELY
#     deny — WebFetch/WebSearch and gh (the pre-authenticated GitHub-write path). We do NOT deny code
#     execution by name: that match is unwinnable (python, ruby, make, shebang'd ./vendor/bin/phpunit,
#     …), so php/node/npm/npx were removed — execution is made harmless by denyWrite above and
#     discouraged by the SKILL's never-execute rule. The deny list also path-scopes the file-write
#     tools (Write/Edit/MultiEdit) away from the snapshot (.pr-review) and .git: denyWrite above only
#     binds Bash's view read-only, but Read/Edit/Write bypass the sandbox and go through permissions, so
#     without this a prompt-injected agent could still rewrite the diff/rules it is judged against or
#     plant a git hook. deny beats allow and blocks symlink escapes, so a path name CAN completely deny
#     these — it fits the same rule as the web/gh denials. The run dir (.pr-review-run) is deliberately
#     NOT tool-denied: agents deliver their reports by Write-ing into it. These patterns are
#     project-root-relative (`/.pr-review/**`), resolved against the session cwd — always the repo root.
#   - hooks: a PreToolUse Bash hook that unconditionally allows Bash, working around
#     anthropics/claude-code#43713 — autoAllowBashIfSandboxed falls back to a permission prompt for any
#     command the static analyzer cannot parse (shell expansions, substitutions, brace/ANSI-C strings),
#     pure friction in an unattended review. A hook's "allow" never overrides a deny, so it cannot
#     weaken the gh/web denials. The heredoc is quoted (<<'JSON') so inner quotes need no escaping; the
#     one dynamic value — the repo root in the denyWrite paths — rides in as @@TOP@@, substituted in
#     launch_review. Each denied path (.git, .pr-review, .pr-review-run) exists by the time the review
#     launches — prep creates all three — so denying them ro-binds an existing inode, never a phantom
#     mount point.
SANDBOX_SETTINGS="$(cat <<'JSON'
{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": true,
    "filesystem": {
      "denyWrite": [ "@@TOP@@/.git", "@@TOP@@/.pr-review", "@@TOP@@/.pr-review-run" ]
    }
  },
  "permissions": {
    "allow": [ "Read", "Task", "Write", "Edit", "MultiEdit", "Bash(rg:*)", "Bash(grep:*)", "Bash(find:*)", "Bash(ugrep:*)", "Bash(bfs:*)", "Bash(git rev-parse:*)", "Bash(git merge-base:*)" ],
    "deny": [ "WebFetch", "WebSearch", "Bash(gh:*)", "Write(/.pr-review/**)", "Edit(/.pr-review/**)", "MultiEdit(/.pr-review/**)", "Write(/.git/**)", "Edit(/.git/**)", "MultiEdit(/.git/**)" ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "cat >/dev/null; printf %s '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"sandboxed auto-allow (claude-code#43713)\"}}'" } ] }
    ]
  }
}
JSON
)"

usage='usage: pr-review [prepare] <pr_id>'

# 1. Arguments.
prep_only=""
pr_id=""
for arg in "$@"; do
  case "$arg" in
    prepare) prep_only=1 ;;
    -*) die "unknown option: $arg ($usage)" ;;
    *)
      if [[ -z "$pr_id" ]]; then pr_id="$arg"
      else die "too many arguments ($usage)"
      fi ;;
  esac
done
[[ -n "$pr_id" ]] || die "$usage"
[[ "$pr_id" =~ ^[0-9]+$ ]] || die "<pr_id> must be a PR number, got: $pr_id"

# 2. Command availability and GitHub CLI setup
command -v git >/dev/null || die "git is not installed. Install it, then try again."
if [[ -z "$prep_only" ]]; then
  command -v claude >/dev/null || die "claude (Claude Code CLI) is not installed or not on PATH."
fi

# 3. Repo root only: REVIEW.md and its relative anchors live there, and the
#    claude session must start there to pick up the repo's skills and rules.
top="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not a git repository."
[[ "$top" == "$(pwd -P)" ]] || die "run this from the repository root: $top"

# The run directory (born in preparation, below) outlives the review. pr-finalize
# drops a posted.md marker in it on a successful post; the relaunch guard in
# section 4 reads that marker, so the path is defined here, once.
run_dir="$top/.pr-review-run"

# The review's safety rests on the sandbox actually starting. failIfUnavailable (in the settings)
# turns a sandbox that cannot start into a hard stop rather than a silent unsandboxed run, but that
# error can be cryptic, and an old Claude Code predating the flag would ignore it. So check the
# Linux/WSL2 dependencies here too, before launch: bubblewrap and socat. macOS uses the built-in
# Seatbelt and needs neither. (Ubuntu 24.04+ also needs an AppArmor userns profile for bwrap — see
# the sandboxing docs — which we cannot detect here; failIfUnavailable is the backstop for that.)
require_sandbox_deps() {
  [[ "$(uname -s)" == "Linux" ]] || return 0
  local missing=()
  command -v bwrap >/dev/null 2>&1 || missing+=(bubblewrap)
  command -v socat >/dev/null 2>&1 || missing+=(socat)
  (( ${#missing[@]} == 0 )) || die "the sandboxed review needs ${missing[*]} on Linux/WSL2 (install: sudo apt-get install ${missing[*]}). It will not run unsandboxed against untrusted PR code — install the package(s), then re-run."
}

launch_review() {
  local prompt="/pr-review:run"
  require_sandbox_deps
  # denyWrite carries the repo root as a @@TOP@@ placeholder in each path (the settings heredoc is
  # quoted); fill it in now that $top is known. It scopes only Bash + children read-only, and only for
  # .git and the review's snapshot/run dirs; Read/Edit/Write bypass the sandbox, so the agents still
  # write REVIEW.md and the run dir.
  local settings="${SANDBOX_SETTINGS//@@TOP@@/$top}"
  # A beat before the exec: the review session takes over the terminal and scrolls everything above
  # away, so this is the only chance to read what preparation did (a skipped dependency sync, a
  # force-push, a head that moved). Not a confirmation — running the command was the decision — so
  # Enter continues and Ctrl-C is the way out. Without a terminal the /dev/tty redirections fail,
  # and the launch proceeds unpaused rather than hanging on a read nobody can answer.
  if { : < /dev/tty; } 2>/dev/null; then
    printf 'pr-review: press Enter to launch the review (Ctrl-C to stop here). ' > /dev/tty
    read -r _ < /dev/tty || true
  fi
  log "launching sandboxed review session: claude \"$prompt\""
  # Effort is pinned here, not in skill frontmatter: the env var beats every
  # other scope (user settings, /effort residue, frontmatter), reaches
  # subagents, and "max" is session-only everywhere else anyway.
  exec env CLAUDE_CODE_EFFORT_LEVEL=max claude --settings "$settings" "$prompt"
}

# 4. An existing REVIEW.md means a review of this PR is in flight (curation, or
#    stacking another run): skip preparation, but refuse a stale file first.
if [[ -f REVIEW.md ]]; then
  file_pr="$(sed -n 's/^pr:[[:space:]]*//p' REVIEW.md | head -n 1)"
  [[ "$file_pr" == "$pr_id" ]] \
    || die "REVIEW.md is for PR #${file_pr:-?}, not #$pr_id. Finish (or delete) that review first."
  branch="$(git rev-parse --abbrev-ref HEAD)"
  [[ "$branch" == "pr/$pr_id" ]] \
    || die "REVIEW.md matches PR #$pr_id but the checked-out branch is '$branch', not 'pr/$pr_id'. Check out the right branch, or delete REVIEW.md and re-run to re-prepare."
  state_file="$top/.pr-review/state.json"
  state_pr="$( { sed -n 's/^[[:space:]]*"prId":[[:space:]]*"\([0-9]*\)".*$/\1/p' "$state_file" | head -n 1; } 2>/dev/null || true )"
  [[ "$state_pr" == "$pr_id" ]] \
    || die "REVIEW.md matches PR #$pr_id but the preparation snapshot ($state_file) is missing or for another PR — the review cannot run without it. Delete REVIEW.md and re-run to re-prepare."
  if [[ -e "$run_dir/posted.md" ]]; then
    die "PR #$pr_id was already finalized by pr-finalize ($run_dir/posted.md). REVIEW.md is kept for follow-up, but this preparation is closed — re-prepare (delete REVIEW.md, then pr-review $pr_id) to review the current head afresh."
  fi
  if [[ -n "$prep_only" ]]; then
    log "REVIEW.md for PR #$pr_id found on branch pr/$pr_id — already prepared; nothing to do."
    exit 0
  fi
  log "REVIEW.md for PR #$pr_id found on branch pr/$pr_id; skipping preparation."
  launch_review
fi

# --- preparation --------------------------------------------------------------

command -v gh >/dev/null || die "GitHub CLI is not installed. Install it (https://github.com/cli/cli#installation), then try again."

# Preparation assembles the base-sourced rule set with pr-assemble-rules (Python 3,
# stdlib only). It rides the same PATH as this script — install-shims links all three
# commands together — so a missing one means the shims were never installed.
command -v python3 >/dev/null || die "python3 is required to assemble the review's rule set. Install it, then try again."
command -v pr-assemble-rules >/dev/null || die "pr-assemble-rules is not on PATH — the plugin's PATH shims are not installed. Run 'claude -p /pr-review:install' once, then try again."

gh auth status >/dev/null 2>&1 \
  || die "GitHub CLI (gh) is installed but not signed in. Run 'gh auth login' and follow the prompts (docs: https://cli.github.com/manual/gh_auth_login), then try again."

normalize_url() {            # any git URL -> lowercase host/owner/repo
  local u="${1%.git}" host
  if [[ "$u" =~ ^[^@]+@([^:]+):(.+)$ ]]; then
    u="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
  elif [[ "$u" =~ ^[a-z]+://([^/]+)/(.+)$ ]]; then
    host="${BASH_REMATCH[1]#*@}"; u="$host/${BASH_REMATCH[2]}"
  fi
  printf '%s' "${u,,}"
}
owner_repo() { printf '%s' "${1#*/}"; }   # host/owner/repo -> owner/repo

find_remote_for() {          # arg: owner/repo  -> remote name on stdout, or return 1
  local target="${1,,}" r
  for r in $(git remote); do
    [[ "$(owner_repo "$(normalize_url "$(git remote get-url "$r")")")" == "$target" ]] \
      && { printf '%s' "$r"; return 0; }
  done
  return 1
}

# 5. Sanity: a clean tree is required; this script never touches your changes.
[[ -z "$(git status --porcelain)" ]] || die "working tree is not clean. This command needs a clean working tree; deal with your uncommitted changes yourself, then run it again."

# 6. Canonical repo = gh's default repo (also the repo gh resolves PRs against).
default_nwo="$(NO_COLOR=1 gh repo set-default --view 2>/dev/null || true)"
# `--view` prints an error sentence and still exits 0 when no default is set, so the
# exit code is useless. A real answer is a single whitespace-free token containing a
# slash; anything else (empty, or the error sentence) means "not set".
if [[ -z "$default_nwo" || "$default_nwo" == *[[:space:]]* || "$default_nwo" != */* ]]; then
  die "No default repository set. Run 'gh repo-set-default', select the upstream repository, then try again."
fi
t="${default_nwo%/}"; base_repo="${t##*/}"; t="${t%/*}"; base_owner="${t##*/}"
base_key="${base_owner,,}/${base_repo,,}"

# 7. Resolve the upstream remote by URL and fetch it (needed for the base branch).
upstream="$(find_remote_for "$base_key")" \
  || die "no local remote points at the default repo ($base_key)."
log "upstream remote: $upstream ($base_key)"
log "fetching $upstream …"
git fetch "$upstream"

# 8. Capture the PR snapshot for the review. The review runs sandboxed with NO
#    network: everything it needs from GitHub is captured here, now, into
#    .pr-review/ — and the review then sees the PR as of preparation, not
#    whatever it mutates into later (the same determinism argument as the one
#    canonical diff). At the repo root, NOT under .git/: Claude Code treats
#    .git/ as a protected write path that prompts on every Write regardless of
#    allow rules — and one convention for all review artifacts beats two. The
#    artifacts survive between sessions, die with the clone, and are hidden
#    from git status via .git/info/exclude (below) instead of by location.
git_dir="$(git rev-parse --absolute-git-dir)"
state_dir="$top/.pr-review"
rm -rf "$state_dir"
mkdir -p "$state_dir"

# The review's run directory dies and is reborn here too: subagent reports
# (r<run>-a<agent>.md, r<run>-v<n>.md) persist across runs of one preparation
# for post-mortem, and are wiped on re-prep — their line numbers die with the
# tree they were measured against. Written only by the review; cleared only here.
rm -rf "$run_dir"
mkdir -p "$run_dir"

# Hide every review artifact from git status: the two directories and the
# review file itself (REVIEW.md must never be committed by accident, and the
# second run must find a clean repo). Per-clone, idempotent.
mkdir -p "$git_dir/info"
for excl in '.pr-review/' '.pr-review-run/' 'REVIEW.md'; do
  grep -qxF "$excl" "$git_dir/info/exclude" 2>/dev/null \
    || printf '%s\n' "$excl" >> "$git_dir/info/exclude"
done

log "capturing PR #$pr_id metadata …"
gh pr view "$pr_id" --json number,title,body,author,state,url,baseRefName,closingIssuesReferences \
  > "$state_dir/pr.json" \
  || die "gh pr view $pr_id failed (bad PR id, or no access?)."

# 9. Scalars the preparation itself needs — a separate, TSV-shaped read, so the
#    snapshot above stays verbatim gh output and this script never parses
#    arbitrary title/body text.
pr_tsv="$(
  gh pr view "$pr_id" --json baseRefName,isCrossRepository,author,state,url,headRefOid \
    --jq '[.baseRefName,(.isCrossRepository|tostring),.author.login,.state,.url,.headRefOid] | @tsv'
)" || die "gh pr view $pr_id failed (bad PR id, or no access?)."
IFS=$'\t' read -r base_ref cross_repo author state url head_oid <<<"$pr_tsv"
[[ -n "$base_ref" ]] || die "could not read PR #$pr_id metadata."
[[ "$state" == "OPEN" ]] || log "! PR #$pr_id is $state; its head branch may no longer exist on the fork."

# 10. Capture every issue the PR references: the Development-panel links
#     (closingIssuesReferences) plus every bare #N in the title/body — extracted
#     mechanically from pr.json ('#' passes through JSON encoding verbatim).
#     Over-capture is harmless: the review judges relevance. The PR's own number
#     is filtered out; a number that is not a fetchable issue is skipped.
issue_nums="$(
  {
    grep -oE '"number":[0-9]+' "$state_dir/pr.json" | grep -oE '[0-9]+'
    grep -oE '#[0-9]+' "$state_dir/pr.json" | tr -d '#'
  } | sort -un | grep -vx "$pr_id" || true
)"
for n in $issue_nums; do
  if gh issue view "$n" --json number,title,body,state,url > "$state_dir/issue-$n.json" 2>/dev/null; then
    log "captured issue #$n"
  else
    rm -f "$state_dir/issue-$n.json"
    log "! #$n is not a fetchable issue (a PR, or no access) — skipped"
  fi
done

# 11. (Re)create the local base branch at the upstream base position.
if [[ "$(git rev-parse --abbrev-ref HEAD)" == "$base_ref" ]]; then
  git reset --hard "$upstream/$base_ref"
else
  git branch -f "$base_ref" "$upstream/$base_ref"
fi
git branch --set-upstream-to="$upstream/$base_ref" "$base_ref" >/dev/null 2>&1 || true

# 12. (Re)create the local PR branch via gh. Check out the base and drop any previous
#    pr/<id> first, so the checkout is a clean reset on re-runs. gh pr checkout fetches
#    the PR head and configures tracking against the fork directly (no remote needed).
local_pr="pr/$pr_id"
git checkout "$base_ref" >/dev/null 2>&1
if git show-ref --verify --quiet "refs/heads/$local_pr"; then
  git branch -D "$local_pr" >/dev/null
fi
gh pr checkout "$pr_id" --branch "$local_pr"

# 13. Rebase onto the base only if the PR is behind it.
if git merge-base --is-ancestor "$base_ref" HEAD; then
  log "$local_pr is already on top of $base_ref; no rebase needed."
  rebased=false
else
  log "rebasing $local_pr onto $base_ref …"
  if git rebase "$base_ref"; then
    rebased=true
  else
    git rebase --abort || true
    die "rebase of $local_pr onto $base_ref failed (conflicts). Aborted; tree restored to the un-rebased PR branch."
  fi
fi

# 14. A rebase rewrote pr/<id>: the PR head on GitHub no longer matches the local
#     one, and every link a review writes against the remote would lie. The push is
#     part of the preparation — no push, no review. Idempotent: a re-run finds no
#     rebase needed and asks nothing.
force_pushed=false
if [[ "$rebased" == true ]]; then
  push_remote="$(git config "branch.$local_pr.remote" 2>/dev/null || true)"
  push_ref="$(git config "branch.$local_pr.merge" 2>/dev/null || true)"
  [[ -n "$push_remote" && -n "$push_ref" ]] \
    || die "$local_pr was rebased but its push destination is missing from branch config. Not pushing — the PR is not ready to review."
  if ! { : < /dev/tty; } 2>/dev/null; then
    die "$local_pr was rebased and needs a force-push, which requires an interactive terminal to confirm. Run this from a shell."
  fi
  printf 'pr-review: %s was rebased. Force-push it to %s (%s)? [y/N] ' "$local_pr" "$push_remote" "$push_ref" > /dev/tty
  answer=""
  read -r answer < /dev/tty || true
  [[ "$answer" == [yY]* ]] \
    || die "force-push declined. $local_pr is rebased locally, but without the push a review's links would not match the PR on GitHub — not ready to review. Re-run when ready."
  log "force-pushing $local_pr (lease: remote must still be at $head_oid) …"
  git push --force-with-lease="$push_ref:$head_oid" "$push_remote" "HEAD:$push_ref" \
    || die "force-push failed — most likely someone pushed to the PR after its metadata was read. Re-run to re-prepare on the new head."
  force_pushed=true
fi

# 15. The canonical diff — computed here, once, post-rebase; every review agent
#     reads this file and never re-derives it (a re-derivation with a different
#     base or flags would silently change the review surface).
git diff "$base_ref"..HEAD > "$state_dir/canonical.diff"
git diff --name-only "$base_ref"..HEAD > "$state_dir/changed-files.txt"

# The authoritative rule set, resolved from the BASE tree — never the PR head. The
# review's standards agents obey it (agent 4 audits against it, agent 6 quotes it), so
# reading it from the checkout would let a fork PR inject instructions into the very
# rules it is judged against (Tenacom/tenacom-ai-tools#1 M3). Like GitHub reading
# CODEOWNERS from the base, pr-assemble-rules resolves CLAUDE.md + .claude/rules/** +
# the glossary overrides from baseSha into .pr-review/rules/. Written before state.json
# (the completeness marker), so a failed assembly leaves no snapshot and the review
# refuses to run rather than proceed with no rules.
log "assembling the base-sourced rule set …"
base_sha="$(git rev-parse "$base_ref")"
pr-assemble-rules "$base_sha" "$state_dir/changed-files.txt" "$state_dir/rules" \
  || die "failed to assemble the base rule set. The review will not run without it — re-run to re-prepare."

# 16. The dependency sync hook — the one thing in the whole preparation that runs code, and it
#     runs only because the reviewed repo asked for it. A PR branch usually declares different
#     dependencies than the tree the reviewer had checked out before: node_modules/ or vendor/
#     stays synced to the PREVIOUS checkout, and the review's agents READ those trees to resolve
#     the APIs the PR calls against — a stale tree means wrong signatures, phantom findings, or
#     missed real ones. Which package manager, which flags, which lock file is repo-specific
#     toolchain knowledge the plugin cannot guess, so it offers a hook instead: an optional
#     .claude/pr-review/sync-deps.sh in the repo. Absent from the base → skipped, silently unless
#     the PR is adding one (below); the feature is pure opt-in, and no auto-detection fallback is
#     coming (heuristics would be a second, worse contract).
#
#     Sourced from the BASE branch, like the rule set, and for a strictly harder reason: the
#     rules are read from the base so a PR cannot rewrite the standards it is judged against
#     (the CODEOWNERS trick), but this is an EXECUTABLE — a fork PR editing it would be
#     arbitrary unsandboxed code execution on the reviewer's machine. Same logic, higher stakes.
#     It is extracted into the snapshot (.pr-review/sync-deps.sh) rather than run from the
#     checkout, so a post-mortem can always answer "what exactly ran?"; the head's copy, if it
#     differs, is announced and ignored. Run via `bash` (no reliance on the exec bit — hence the
#     .sh), unsandboxed, with network: preparation already is the network-capable phase.
#
#     The residual hole is real and deliberate: the script's whole job is to run an installer
#     against HEAD-CONTROLLED manifests, so a malicious PR's lifecycle scripts (or a poisoned
#     dependency it adds) execute here, unsandboxed. The repo owner who commits the script
#     accepts that; the README says so loudly and recommends `npm ci --ignore-scripts` /
#     `composer install --no-scripts --no-plugins`. This is why prep must never gain a second
#     execution path by accident: the invariant is "preparation executes nothing except this,
#     and only on the repo's explicit invitation".
#
#     Guards, symmetric with the clean-tree entry check (section 5): the script may install
#     things, and nothing else. A nonzero exit, a moved HEAD, a switched branch, or a dirty tree
#     each fail the preparation, naming what the script did wrong. No auto-reset — a buggy
#     script's mess is evidence, not something to silently destroy. And it runs BEFORE state.json
#     (below): a failed sync leaves no completeness marker, so the review refuses to run, exactly
#     like a failed rules assembly.
#
#     Its output goes to stderr, with the rest of the preparation's progress: the reviewer must
#     see the installer's chatter (a poorly-written script can exit 0 on a failed `npm ci`, and
#     a script doing something fishy shows it there), while stdout stays the machine-readable
#     JSON object section 18 prints.
sync_script=".claude/pr-review/sync-deps.sh"
synced_deps=false
# A REGULAR FILE, or nothing — and the mode field is the only thing that says so. `git show
# <sha>:<dir>` on a tree succeeds and prints a bare-filename listing, which fed to bash would run
# those names as commands; a symlink is reported by ls-tree as type "blob" too, and its "content"
# is the link target, which bash would likewise run. Both are refused here rather than executed.
# An entry that exists but is neither is a misconfiguration, and a misconfigured hook must fail
# loudly: silently skipping it would leave the repo owner believing the sync runs when it does not.
sync_entry="$(git ls-tree "$base_sha" -- "$sync_script")"
if [[ -z "$sync_entry" ]]; then
  # Not on the base, but on the head: the hook is being ADDED by this PR — the one case where
  # "absent, so skipped" would look like a bug to the person who just wrote the file. Base-sourcing
  # is exactly what makes it inert here, so say so and name the fix. A line of output, not a stop:
  # the repo has no working hook yet, which is the same position as a repo that wants none.
  if [[ -n "$(git ls-tree HEAD -- "$sync_script")" ]]; then
    log "! $sync_script exists on the PR head but not on $base_ref — NOT run. The hook is always taken from the base branch, so a PR cannot introduce code into the preparation. Merge it into $base_ref for it to take effect."
  fi
else
  sync_blob="$(printf '%s\n' "$sync_entry" | awk '$1 ~ /^100/ && $2 == "blob" { print $3 }')"
  [[ -n "$sync_blob" ]] \
    || die "$sync_script exists on $base_ref but is not a regular file (mode $(printf '%s\n' "$sync_entry" | awk '{ print $1 }')). The dependency-sync hook must be a plain shell script — a directory or a symlink is refused, not executed. Fix it on $base_ref, then re-run to re-prepare."
  head_blob="$(git ls-tree HEAD -- "$sync_script" | awk '$1 ~ /^100/ && $2 == "blob" { print $3 }')"
  [[ "$head_blob" == "$sync_blob" ]] \
    || log "! $sync_script differs on the PR head; running the base version."
  git cat-file blob "$sync_blob" > "$state_dir/sync-deps.sh"
  branch_before="$(git rev-parse --abbrev-ref HEAD)"
  head_before="$(git rev-parse HEAD)"
  log "syncing dependencies ($sync_script, from $base_ref) …"
  # The branch check comes before the HEAD check: a script that checks out another branch trips
  # both, and "switched the branch" is the more useful diagnosis. HEAD-moved then catches what is
  # left — a commit or a reset on the branch we are standing on.
  # The exit code is captured into a variable rather than read from $? after an `if !` (where the
  # negation, not the script, would set it), and reported: an installer's code often IS the
  # diagnosis (npm's 1 vs composer's 2), and it is the one thing a script that prints nothing
  # still tells us.
  sync_rc=0
  bash "$state_dir/sync-deps.sh" >&2 || sync_rc=$?
  (( sync_rc == 0 )) \
    || die "$sync_script failed (exit code $sync_rc; see its output above). Dependencies are not in sync with the PR — not ready to review. Fix the script (or its inputs), then re-run to re-prepare."
  [[ "$(git rev-parse --abbrev-ref HEAD)" == "$branch_before" ]] \
    || die "$sync_script switched the checked-out branch (from $branch_before to $(git rev-parse --abbrev-ref HEAD)). It must install dependencies and nothing else. The tree is left as the script made it — inspect it, fix the script, then re-run to re-prepare."
  [[ "$(git rev-parse HEAD)" == "$head_before" ]] \
    || die "$sync_script moved HEAD (from $head_before to $(git rev-parse HEAD)). It must install dependencies and nothing else. The tree is left as the script made it — inspect it, fix the script, then re-run to re-prepare."
  [[ -z "$(git status --porcelain)" ]] \
    || die "$sync_script left the working tree dirty. It must install dependencies and nothing else — a package manager that rewrites a lock file (npm install rather than npm ci, composer update rather than composer install) is the usual cause. The tree is left as the script made it — inspect it with 'git status', fix the script, then re-run to re-prepare."
  synced_deps=true
fi

# 17. The state marker, written LAST: its presence means the capture is complete and consistent —
#     a failed preparation leaves no state.json, and the review refuses to run without one. `head`
#     is the post-push truth: thanks to the force-push above, it is also the PR head on GitHub.
#     `syncedDeps` records whether the hook ran, so a post-mortem can tell a review of a synced
#     tree from one of a stale tree; nothing reads it today.
cat > "$state_dir/state.json" <<JSON
{
  "prId": "$pr_id",
  "baseBranch": "$base_ref",
  "baseSha": "$base_sha",
  "head": "$(git rev-parse HEAD)",
  "rebased": $rebased,
  "forcePushed": $force_pushed,
  "syncedDeps": $synced_deps,
  "capturedAt": "$(date -u +%FT%TZ)"
}
JSON

# 18. Emit the prepared state as JSON on stdout.
cat <<JSON
{
  "prId": "$pr_id",
  "author": "$author",
  "state": "$state",
  "baseBranch": "$base_ref",
  "prBranch": "$local_pr",
  "upstreamRemote": "$upstream",
  "crossRepo": $cross_repo,
  "rebased": $rebased,
  "forcePushed": $force_pushed,
  "syncedDeps": $synced_deps,
  "artifacts": "$state_dir",
  "url": "$url"
}
JSON

# 19. Review, or stop here if prepare only.
if [[ -n "$prep_only" ]]; then
  log "$local_pr is prepared and checked out. Review with: pr-review $pr_id — or run /pr-review:run from a Claude session on this branch."
  exit 0
fi
launch_review
