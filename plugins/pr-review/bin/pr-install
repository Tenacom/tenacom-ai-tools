#!/usr/bin/env bash
# pr-install — put `pr-review`, `pr-finalize`, `pr-check`, `pr-cleanup`, and `pr-assemble-rules` on the PATH.
#
# This plugin ships the real scripts in its bin/ directory, which Claude Code adds to
# the Bash tool's PATH while the plugin is enabled — but NOT to your interactive
# shell's PATH, and `pr-review` must be typeable in a bare shell before any session
# exists. This script bridges that gap.
#
# `pr-review`, `pr-finalize`, `pr-check` and `pr-cleanup` are the four end-user
# commands; `pr-assemble-rules` is an internal helper `pr-review` invokes during preparation
# (it resolves the review's rule set from the base branch). It must be on the same
# PATH so `pr-review` can find it by bare name — `pr-review` is deliberately
# location-independent — hence it is shimmed alongside the three, not called by path.
#
# It is run two ways, both equivalent:
#   - at install, and again after each plugin update:  claude -p /pr-review:install
#   - by hand, if a link ever breaks: pr-install
#
# What it does, idempotently:
#   1. Self-locates — the live plugin version's bin/ dir, even via a symlink.
#   2. Copies the commands, and the shared modules they rely on, into a STABLE dir
#      (~/.local/share/pr-review/bin), refreshing only
#      when they differ (first run, or after a plugin update). The copies are
#      independent of the version-pinned plugin cache, so a PATH entry can lag a
#      version behind but can never dangle when an old cache version is
#      garbage-collected (~7 days after an update).
#   3. Points ~/.local/bin/<cmd> at each command's stable copy with a symlink —
#      created if absent, repaired if it points elsewhere, and left untouched if a
#      human put a real file there. The modules are copied only, never symlinked:
#      the commands import them from beside their own copies, so they need no PATH entry.
#
# Output goes to stderr only: the stdout of `claude -p /pr-review:install` is
# injected into Claude's context, so this keeps it empty. Failures are non-fatal.

set -euo pipefail

# 1. Self-locate. readlink -f canonicalises through the ~/.local/bin symlink (when
#    run by hand as a bare command) and through the plugin's cache bin dir (when
#    the install skill runs it in a session); BASH_SOURCE[0] is robust where $0 is
#    not. GNU coreutils — fine on the Ubuntu/WSL target.
here="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

store="$HOME/.local/share/pr-review/bin"   # stable home for the on-PATH copies
bindir="$HOME/.local/bin"                   # where the commands must be typeable
cmds=(pr-review pr-finalize pr-check pr-cleanup pr-assemble-rules)
modules=(pr_review_lint.py pr_review_cleanup.py)   # copied beside the commands, never symlinked — imported, not run

mkdir -p "$store" "$bindir"

changed=0
for cmd in "${cmds[@]}"; do
  src="$here/$cmd"
  dst="$store/$cmd"

  [[ -f "$src" ]] \
    || { printf 'pr-install: %s is missing from the plugin bin (%s) — broken install?\n' "$cmd" "$here" >&2; exit 1; }

  # 2. Refresh the stable copy only when it actually differs.
  if [[ ! -f "$dst" ]] || ! cmp -s "$src" "$dst"; then
    cp "$src" "$dst"
    chmod +x "$dst"
    changed=1
  fi

  # 3. Maintain the PATH symlink → stable copy. Never clobber a real file.
  link="$bindir/$cmd"
  if [[ -L "$link" ]]; then
    [[ "$(readlink -f "$link")" == "$(readlink -f "$dst")" ]] \
      || { ln -sfn "$dst" "$link"; changed=1; }
  elif [[ ! -e "$link" ]]; then
    ln -s "$dst" "$link"
    changed=1
  else
    printf 'pr-install: %s exists and is not a symlink — leaving it as is.\n' "$link" >&2
  fi
done

# The shared modules ride along in the stable dir so the commands can import them
# from beside their own copies. Copy-only: they are imported, not run, so they need
# no PATH symlink and no execute bit.
for mod in "${modules[@]}"; do
  src="$here/$mod"
  dst="$store/$mod"

  [[ -f "$src" ]] \
    || { printf 'pr-install: %s is missing from the plugin bin (%s) — broken install?\n' "$mod" "$here" >&2; exit 1; }

  if [[ ! -f "$dst" ]] || ! cmp -s "$src" "$dst"; then
    cp "$src" "$dst"
    changed=1
  fi
done

# A status line (stderr): the human sees the result of the run, while stdout stays
# empty so nothing is injected into Claude's context (see the header note above).
if [[ "$changed" -eq 1 ]]; then
  printf 'pr-install: pr-review, pr-finalize, pr-check, pr-cleanup and pr-assemble-rules are linked in %s.\n' "$bindir" >&2
else
  printf 'pr-install: already current; nothing to do.\n' >&2
fi

# The one thing this script cannot do: edit your interactive shell's PATH.
case ":${PATH:-}:" in
  *":$bindir:"*) : ;;
  *) printf 'pr-install: note — %s is not on your PATH. Add it (a fresh login shell usually does on Ubuntu/WSL once the dir exists).\n' "$bindir" >&2 ;;
esac
