#!/usr/bin/env python3
"""pr-check — lint a curated REVIEW.md offline, without posting anything.

A companion to pr-finalize for the curation loop. As you tick checkboxes and edit
findings, pr-check tells you whether the file is postable yet: it runs the very
same parse and lint pr-finalize runs — the shared pr_review_lint module — and
reports every problem in one sorted, clickable sweep, or says the file is clean.
Because it is the same grammar and the same linter, a file pr-check calls clean is
a file pr-finalize will accept; the point is to find the misfiled finding, the
out-of-diff anchor, the broken link now, at the speed of a local command, instead
of at the end of pr-finalize's live-head check and GitHub round-trip.

It touches nothing but the filesystem: no network, no gh, no git, no writes. It
reads REVIEW.md and the preparation snapshot's diff (.pr-review/canonical.diff),
which it needs to tell an in-diff finding from an out-of-diff one — so it must run
in a prepared repository, from its root, and refuses with a clear message rather
than guess when the snapshot is absent. It never posts and never curates; it only
answers "would this post?".

Usage:  pr-check    lint REVIEW.md and report; exit 0 if clean, 1 if not
"""

from __future__ import annotations

import sys
from pathlib import Path

# The grammar, model and linter live in pr_review_lint.py beside this script, and
# the shared low-level helpers in pr_review_common.py; resolve() follows the
# ~/.local/bin symlink pr-install creates back to the real bin dir, where
# pr-install copies the modules alongside this file (see pr-finalize for the same
# idiom).
sys.path.insert(0, str(Path(__file__).resolve().parent))
from pr_review_common import (
    REVIEW_NAME,
    STATE_DIR_NAME,
    die,
    log,
    set_prog,
)
from pr_review_lint import (
    Problem,
    bail_on_problems,
    lint,
    parse_diff_ranges,
    parse_review,
)

PROG = "pr-check"
set_prog(PROG)
STATE_DIR = Path(STATE_DIR_NAME)
REVIEW = Path(REVIEW_NAME)
CANON = STATE_DIR / "canonical.diff"


def main(argv: list[str]) -> int:
    """Lint REVIEW.md against the snapshot diff; exit 1 if anything would block posting."""
    if argv:
        die(f"unexpected argument: {argv[0]} (usage: pr-check)")

    if not REVIEW.is_file():
        die(f"no {REVIEW_NAME} at the repository root — nothing to check. Run "
            "pr-check from the repo root, after a review has written it.")
    if not CANON.is_file():
        die(f"no {CANON} — the preparation snapshot's diff is missing, and "
            "pr-check needs it to tell in-diff findings from out-of-diff ones. "
            "Prepare and review first: pr-review <id>.")

    ranges = parse_diff_ranges(CANON.read_text())
    problems: list[Problem] = []
    body, body_line, sections = parse_review(REVIEW.read_text(), problems)
    lint(body, body_line, sections, ranges, problems)
    bail_on_problems(problems, PROG)  # prints the batch and exits 1 if any

    log(f"{REVIEW_NAME} is clean — every checked finding is postable.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
