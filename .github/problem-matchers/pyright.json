{
  "problemMatcher": [
    {
      "owner": "pyright",
      "pattern": [
        {
          "regexp": "^\\s*(\\S.*):(\\d+):(\\d+) - (error|warning): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
